# Default to local Ollama for >=90% of requests
LLM_DEFAULT_PROVIDER=ollama
LLM_TARGET_LOCAL_RATIO=0.90
LLM_ENABLE_CLOUD_FALLBACK=true

# Optional one-run override (usually set via CLI)
# LLM_FORCE_PROVIDER=ollama

# Local Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Copilot / GitHub Models fallback
# Required for cloud fallback to Copilot-backed models
GITHUB_TOKEN=ghp_your_token_here
COPILOT_MODEL=gpt-4.1-mini
COPILOT_BASE_URL=https://models.inference.ai.azure.com/chat/completions

# Optional Gemini fallback
# GEMINI_API_KEY=your_gemini_key
# GEMINI_MODEL=gemini-1.5-flash
